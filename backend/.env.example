# Server
PORT=8080
NODE_ENV=development
APP_CLIENT_TOKEN=change_this_demo_token
CORS_ORIGIN=*

# NewsAPI credentials. Keep this on the backend only.
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_BASE_URL=https://newsapi.org
DEFAULT_COUNTRY=us
DEFAULT_PAGE_SIZE=50

# Cache / quota
CACHE_TTL_TOP_HEADLINES_SECONDS=900
CACHE_TTL_EVERYTHING_SECONDS=3600
CACHE_TTL_SOURCES_SECONDS=86400
CACHE_TTL_READER_SECONDS=86400
REQUESTS_PER_MINUTE=60

# Reader extraction
READER_MAX_HTML_CHARS=1200000
READER_MAX_TEXT_CHARS=50000

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
ENABLE_BREAKING_NEWS_JOB=false
BREAKING_NEWS_CRON=*/15 * * * *
BREAKING_NEWS_TOPIC=breaking-news

# PostgreSQL. Railway internal URLs only work when backend is deployed in the same Railway project.
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=false
PG_POOL_MAX=5

# Upstash Redis REST
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Twilio Verify for SMS OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid for email OTP
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_FROM_EMAIL=verified_sender@example.com
OTP_SECRET=change_this_secret_before_production
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
